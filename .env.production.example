# Required: the domain you want to serve Open Sunsama on
# Example: schedule.yourdomain.com
DOMAIN=schedule.yourdomain.com

# Required: PostgreSQL credentials
POSTGRES_USER=opensunsama
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=opensunsama

# Required: JWT secret (min 32 chars)
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS

# Optional: Redis URL for multi-instance scaling
# REDIS_URL=redis://redis:6379

# Optional: S3-compatible storage for file uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=opensunsama-uploads
# S3_ENDPOINT=

# Optional: email provider (used for notifications/password reset)
# RESEND_API_KEY=

# Optional: Web Push VAPID keys
# Generate with: npx web-push generate-vapid-keys
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
