# Open Sunsama API Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/opensunsama

# JWT Secret - REQUIRED for authentication
# Generate a secure random string with at least 32 characters
# Example: openssl rand -base64 32
JWT_SECRET=your-secure-random-string-min-32-chars

# JWT token expiration (optional, defaults to 7d)
# JWT_EXPIRES_IN=7d

# How long (in days) an expired token can still be exchanged for a fresh one
# via POST /auth/refresh — the sliding-session grace window. Returning users
# within this window are renewed instead of logged out. (optional, defaults to 30)
# JWT_REFRESH_LEEWAY_DAYS=30

# Server configuration
API_PORT=3001
API_HOST=localhost

# URLs (REQUIRED for OAuth redirects in production)
# Local: http://localhost:3001 / http://localhost:3000
# Production: https://api.opensunsama.com / https://opensunsama.com
API_URL=http://localhost:3001
WEB_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Web Push (VAPID) - Required for push notifications
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@opensunsama.com

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (Outlook)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Calendar Integration
# Encryption key for OAuth tokens (32 bytes = 64 hex characters)
# Generate with: openssl rand -hex 32
CALENDAR_ENCRYPTION_KEY=your-32-byte-hex-key-here

# Desktop Releases
# Secret key for authenticating release uploads from GitHub Actions
# Must match RELEASE_SECRET in GitHub Actions secrets
RELEASE_SECRET=
